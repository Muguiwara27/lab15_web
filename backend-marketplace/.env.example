# ============================================
# MARKETPLACE PRO - BACKEND CONFIGURATION
# ============================================
# Uso en Railway (producción):
#   Railway inyecta automáticamente MYSQL_URL
#   No necesitas configurar nada más para la DB
#
# Uso en Render + Railway:
#   Render NO recibe MYSQL_URL automáticamente.
#   Debes crear la variable DATABASE_URL en Render
#   con el valor de MYSQL_URL de Railway.
#
# Uso local (desarrollo):
#   Usa DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD
# ============================================

# --- Database: Railway (producción) ---
# DATABASE_URL=mysql://user:password@host:port/dbname
# MYSQL_URL=mysql://user:password@host:port/dbname

# --- Database: Local (desarrollo) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=marketplace_pro
DB_USER=root
DB_PASSWORD=

# --- JWT ---
JWT_SECRET=change_this_to_a_random_secure_string
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=3001

# --- Frontend (CORS) ---
FRONTEND_URL=http://localhost:3000
